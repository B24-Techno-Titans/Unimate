#:import dp kivy.metrics.dp
#:import Theme theme.Theme

# Button press glow and canvas sync remain in Python (dynamic _pressed state).
<GlowFlatButton>:
    background_normal: ''
    background_down: ''
    background_color: 0, 0, 0, 0
    bold: True

<GlowIconButton>:
    background_normal: ''
    background_down: ''
    background_color: 0, 0, 0, 0
    bold: True
    font_size: '28sp'
